    {
      "parameters": {
        "jsCode": "const managers = $input.all();\n\n// Только активные менеджеры\nconst active = managers.filter(m => m.json.active === true);\n\nif (active.length === 0) {\n    throw new Error(\"Нет активных менеджеров\");\n}\n\n// Если queue пустая - считаем её равной 0\nactive.forEach(m => {\n    m.json.queue = Number(m.json.queue) || 0;\n});\n\n// Сортировка по очереди\nactive.sort((a, b) => a.json.queue - b.json.queue);\n\n// Берем первого (у него минимальная очередь)\nconst selected = active[0];\n\nreturn [{\n    json: {\n        manager: selected.json.manager,\n        chat_id: selected.json.chat_id,\n        row_number: selected.json.row_number,\n\n        queue: selected.json.queue,\n        new_queue: selected.json.queue + 1,\n\n        last_order: new Date().toISOString()\n    }\n}];"
      },
