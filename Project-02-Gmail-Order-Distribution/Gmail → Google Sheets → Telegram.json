    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text.replace(/\\n/g, \" \");\n\nfunction extract(start, end) {\n  const regex = new RegExp(\n    start + \"\\\\s*:?\\\\s*(.*?)\\\\s*\" + end,\n    \"i\"\n  );\n\n  const match = text.match(regex);\n\n  return match ? match[1].trim() : \"\";\n}\n\nreturn [{\n  json: {\n    order: extract(\"Номер заказа\", \"Дата заказа\"),\n    date: extract(\"Дата заказа\", \"Имя клиента\"),\n    name: extract(\"Имя клиента\", \"Фамилия\"),\n    surname: extract(\"Фамилия\", \"Телефон\"),\n    phone: extract(\"Телефон\", \"Email\"),\n    email: extract(\"Email\", \"Товар\"),\n    product: extract(\"Товар\", \"Количество\"),\n    quantity: extract(\"Количество\", \"Стоимость\"),\n    price: extract(\"Стоимость\", \"Адрес доставки\"),\n    address: extract(\"Адрес доставки\", \"Комментарий\\\\s*клиента\"),\n    comment: extract(\"Комментарий\\\\s*клиента\", \"Спасибо\")\n  }\n}];"
      },
